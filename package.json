{
  "name": "agent-skill-marketplace-local",
  "version": "0.1.0",
  "private": true,
  "description": "Machine-global skill marketplace for local agents",
  "type": "commonjs",
  "bin": {
    "skill-marketplace": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "init:skills": "node dist/cli.js init",
    "list:skills": "node dist/cli.js list",
    "resolve": "node dist/cli.js resolve",
    "runtime": "node dist/cli.js runtime",
    "diary:set": "node dist/cli.js diary-set",
    "diary:list": "node dist/cli.js diary-list",
    "install:global": "npm link"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3"
  }
}
